# Gemini API key (env var name is a legacy Dify artifact — rename pending)
NEXT_PUBLIC_DIFY_API_KEY=

# Neon Postgres connection strings
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Feature flags
# Set to "true" to enable function-call elicitation cards (Phase 2, Chunk B+).
# Leave as "false" to run in V2.6 prose-only mode.
ENABLE_FUNCTION_CALL_ELICITATION=false
